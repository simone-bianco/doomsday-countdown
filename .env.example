APP_NAME="AI Laravel Starter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production override: APP_URL=https://doomsday-clock.com
# Keep this local example unchanged; runtime URL generation remains environment-driven.
APP_URL=http://localhost:8000
AI_STARTER_BACKOFFICE_PATH=backoffice
AI_STARTER_DEMO_AGENT_SLUG=quickstart-assistant

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Daily application backup: 03:00 Europe/Rome. Production must include an off-host disk such as s3.
BACKUP_NAME=doomsday-clock
BACKUP_DISKS=backup
BACKUP_TIME=03:00
BACKUP_TIMEZONE=Europe/Rome
BACKUP_CLEANUP_TIME=03:30
BACKUP_MONITOR_TIME=04:00
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFICATION_EMAIL=
BACKUP_VERIFY=true
BACKUP_MAX_AGE_DAYS=1
BACKUP_MAX_STORAGE_MB=10240

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Production GA4: VITE_GOOGLE_ANALYTICS_ID=G-2L9QPGWKVL
# Leave both blank locally. GTM, when configured, remains the preferred owner.
VITE_GOOGLE_TAG_MANAGER_ID=
VITE_GOOGLE_ANALYTICS_ID=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

KEY_ROTATOR_ENCRYPT_KEYS=true
FORM_BRIDGE_CAPTURE_DUMPS=false
