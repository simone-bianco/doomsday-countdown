{
  "name": "simone-bianco/laravel-ai-agents",
  "version": "1.0.0",
  "description": "Domain-agnostic DB-driven AI agents for Laravel, built on LarAgent.",
  "type": "library",
  "license": "MIT",
  "authors": [{"name": "Simone Bianco"}],
  "require": {
    "php": ">=8.3",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/console": "^12.0|^13.0",
    "illuminate/database": "^12.0|^13.0",
    "illuminate/http": "^12.0|^13.0",
    "spatie/laravel-data": "^4.0",
    "spatie/laravel-package-tools": "^1.92",
    "maestroerror/laragent": "*",
    "simone-bianco/laravel-key-rotator": "*",
    "simone-bianco/laravel-fill-variables": "*"
  },
  "suggest": {
    "simone-bianco/laravel-page-chat": "Required if you use PageChatStorageDriver for conversation history"
  },
  "autoload": {
    "psr-4": {
      "SimoneBianco\\LaravelAiAgents\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SimoneBianco\\LaravelAiAgents\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["SimoneBianco\\LaravelAiAgents\\LaravelAiAgentsServiceProvider"]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
